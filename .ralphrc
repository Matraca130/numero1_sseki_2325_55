# .ralphrc - Ralph project configuration for Axon Platform
# Generated by: manual setup
# Documentation: https://github.com/frankbria/ralph-claude-code

# =============================================================================
# PROJECT IDENTIFICATION
# =============================================================================
PROJECT_NAME="axon-mindmap"
PROJECT_TYPE="typescript"
CLAUDE_CODE_CMD="claude"

# =============================================================================
# LOOP SETTINGS
# =============================================================================
MAX_CALLS_PER_HOUR=100
CLAUDE_TIMEOUT_MINUTES=30
CLAUDE_OUTPUT_FORMAT="text"

# =============================================================================
# TOOL PERMISSIONS
# =============================================================================
ALLOWED_TOOLS="Write,Read,Edit,Grep,Glob,Agent,WebFetch,WebSearch,Bash,Bash(git add *),Bash(git commit *),Bash(git diff *),Bash(git log *),Bash(git status),Bash(git status *),Bash(git push *),Bash(git pull *),Bash(git fetch *),Bash(git checkout *),Bash(git branch *),Bash(git stash *),Bash(git merge *),Bash(git tag *),Bash(npm *),Bash(npx *),Bash(node *),Bash(cd *),Bash(powershell *),Bash(ls *),Bash(cat *),Bash(wc *),Bash(mkdir *)"

# =============================================================================
# SESSION MANAGEMENT
# =============================================================================
SESSION_CONTINUITY=true
SESSION_EXPIRY_HOURS=2

# =============================================================================
# TASK SOURCES
# =============================================================================
TASK_SOURCES="local"

# =============================================================================
# CIRCUIT BREAKER THRESHOLDS
# =============================================================================
CB_NO_PROGRESS_THRESHOLD=3
CB_SAME_ERROR_THRESHOLD=5
CB_OUTPUT_DECLINE_THRESHOLD=70
CB_COOLDOWN_MINUTES=30
CB_AUTO_RESET=true

# =============================================================================
# ADVANCED SETTINGS
# =============================================================================
CLAUDE_AUTO_UPDATE=true
CLAUDE_MIN_VERSION="2.0.76"
RALPH_VERBOSE=false
