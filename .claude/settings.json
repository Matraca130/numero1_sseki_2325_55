{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit(/.claude/agent-memory/**/*.md)",
      "Write(/.claude/agent-memory/**/*.md)",
      "Edit(/.claude/agent-memory/*.md)",
      "Write(/.claude/agent-memory/*.md)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/check-agent-opus.cjs",
            "statusMessage": "Verificando model: opus..."
          }
        ]
      }
    ]
  }
}
